# ============================
# COPY FILE INI JADI .env
# Lalu isi dengan nilai yang benar
# ============================

# Database PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB_NAME?schema=public"

# JWT Secret untuk Mobile App (min 32 karakter, random)
JWT_SECRET="ganti-dengan-string-random-yang-panjang-dan-rahasia"

# File upload
UPLOAD_DIR="./public/uploads"
MAX_IMAGE_SIZE="2048"
MAX_AUDIO_SIZE="10240"
MAX_VIDEO_SIZE="51200"

# Cookie secure flag
# Set "true" HANYA jika server sudah pakai HTTPS (domain + SSL).
# Untuk akses lewat HTTP (mis. http://IP-VPS), biarkan "false" atau kosong,
# kalau tidak cookie session tidak akan terkirim browser dan login gagal redirect.
COOKIE_SECURE="false"
