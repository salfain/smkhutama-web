# ============================================================
# File ini untuk docker-compose.
# Copy jadi .env lalu isi nilai yang benar.
# JANGAN commit file .env ke git!
# ============================================================

# ── Database credentials (dipakai oleh service db & app) ──
POSTGRES_USER=root
POSTGRES_PASSWORD=1
POSTGRES_DB=db_cbt_smk_hutama

# Database URL untuk Next.js/Prisma
# Host "db" = nama service di docker-compose
DATABASE_URL=postgresql://root:1@db:5432/db_cbt_smk_hutama

# JWT Secret untuk Mobile App (min 32 karakter, random string)
JWT_SECRET=ganti-dengan-string-random-yang-sangat-panjang-dan-rahasia

# File upload settings
UPLOAD_DIR=./public/uploads
MAX_IMAGE_SIZE=2048
MAX_AUDIO_SIZE=10240
MAX_VIDEO_SIZE=51200

# Set "true" jika sudah pakai HTTPS/domain, "false" jika masih HTTP
COOKIE_SECURE=true
