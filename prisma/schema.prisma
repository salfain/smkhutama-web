// Prisma Schema - CBT SMK HUTAMA
// Database: PostgreSQL

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  TEACHER
  STUDENT
  LANDING_ADMIN
  COUNSELOR
  PIKET
}

enum Gender {
  MALE
  FEMALE
}

enum QuestionType {
  MULTIPLE_CHOICE
  MULTIPLE_CHOICE_COMPLEX
  TRUE_FALSE
  MATCHING
  SHORT_ANSWER
  ESSAY
}

enum MediaType {
  NONE
  IMAGE
  AUDIO
  VIDEO
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum ExamStatus {
  DRAFT
  ACTIVE
  CLOSED
}

enum ExamType {
  UH      // Ulangan Harian
  UTS     // Ujian Tengah Semester
  UAS     // Ujian Akhir Semester
  US      // Ujian Sekolah
  TRYOUT  // Tryout / Latihan
  LAINNYA
}

enum AttemptStatus {
  NOT_STARTED
  IN_PROGRESS
  SUBMITTED
  AUTO_SUBMITTED
}

enum Semester {
  GANJIL
  GENAP
}

enum CounselingType {
  PRIBADI
  SOSIAL
  BELAJAR
  KARIR
}

enum CounselingStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  REFERRED
}

enum ViolationCategory {
  RINGAN
  SEDANG
  BERAT
}

enum RequestStatus {
  PENDING
  APPROVED
  SCHEDULED
  DONE
  REJECTED
}

enum SummonStatus {
  PENDING
  SENT
  DONE
}

enum QuestionSetStatus {
  DRAFT
  SUBMITTED
  APPROVED
  USED
}

enum QuestionSetSource {
  TEACHER_IMPORT
  ADMIN_IMPORT
}

// ============================================
// MODELS
// ============================================

/// Profil sekolah (hanya 1 record)
model SchoolProfile {
  id              String   @id @default(uuid())
  name            String
  logo            String?
  address         String?
  npsn            String?
  principalName   String?  @map("principal_name")
  letterhead      String?
  digitalSignature String? @map("digital_signature")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("school_profiles")
}

/// Tahun ajaran
model AcademicYear {
  id        String   @id @default(uuid())
  year      String   // e.g. "2025/2026"
  semester  Semester
  isActive  Boolean  @default(false) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  exams Exam[]

  @@map("academic_years")
}

/// User (admin, guru, siswa)
model User {
  id           String   @id @default(uuid())
  name         String
  username     String   @unique
  email        String?  @unique
  passwordHash String   @map("password_hash")
  role         Role
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  student Student?
  teacher Teacher?
  counselor Counselor?

  @@map("users")
}

/// Jurusan
model Major {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  classes  Class[]
  students Student[]
  subjects Subject[]

  @@map("majors")
}

/// Kelas
model Class {
  id        String   @id @default(uuid())
  name      String   // e.g. "XII TKJ 1"
  grade     String   // X, XI, XII
  majorId   String   @map("major_id")
  homeroomTeacherId String? @map("homeroom_teacher_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  major    Major     @relation(fields: [majorId], references: [id])
  homeroomTeacher Teacher? @relation("Homeroom", fields: [homeroomTeacherId], references: [id])
  students Student[]
  examParticipants ExamClass[]
  teacherAttendances TeacherAttendance[]

  @@map("classes")
}

/// Mata pelajaran
model Subject {
  id        String   @id @default(uuid())
  name      String
  code      String   @unique
  majorId   String?  @map("major_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  major     Major?    @relation(fields: [majorId], references: [id])
  teachers  Teacher[]
  questions Question[]
  questionSets QuestionSet[]
  exams     Exam[]

  @@map("subjects")
}

/// Profil siswa
model Student {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  nis       String?  @unique
  nisn      String?  @unique
  classId   String?  @map("class_id")
  majorId   String?  @map("major_id")
  gender    Gender?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  class    Class?  @relation(fields: [classId], references: [id])
  major    Major?  @relation(fields: [majorId], references: [id])
  attempts StudentExamAttempt[]
  counselingCases    CounselingCase[]
  violationRecords   ViolationRecord[]
  achievementRecords AchievementRecord[]
  counselingRequests CounselingRequest[]
  parentSummons      ParentSummon[]
  homeVisits         HomeVisit[]
  surveyResponses    SurveyResponse[]
  tardinessRecords   StudentTardiness[]
  permits            StudentPermit[]

  @@map("students")
}

/// Profil guru
model Teacher {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  nip       String?  @unique
  subjectId String?  @map("subject_id")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   Subject? @relation(fields: [subjectId], references: [id])
  questions Question[]
  questionSets QuestionSet[]
  exams     Exam[]
  homeroomClasses Class[] @relation("Homeroom")
  attendances TeacherAttendance[]

  @@map("teachers")
}

/// Paket bank soal hasil import guru/admin
model QuestionSet {
  id                  String            @id @default(uuid())
  title               String
  description         String?
  subjectId           String            @map("subject_id")
  ownerTeacherId      String            @map("owner_teacher_id")
  createdByUserId     String?           @map("created_by_user_id")
  createdByRole       Role              @default(TEACHER) @map("created_by_role")
  source              QuestionSetSource @default(TEACHER_IMPORT)
  examType            ExamType          @default(UTS) @map("exam_type")
  grade               String?
  sourceFileName      String?           @map("source_file_name")
  status              QuestionSetStatus @default(DRAFT)
  totalQuestions      Int               @default(0) @map("total_questions")
  multipleChoiceCount Int               @default(0) @map("multiple_choice_count")
  essayCount          Int               @default(0) @map("essay_count")
  invalidCount        Int               @default(0) @map("invalid_count")
  createdAt           DateTime          @default(now()) @map("created_at")
  updatedAt           DateTime          @updatedAt @map("updated_at")

  subject      Subject    @relation(fields: [subjectId], references: [id])
  ownerTeacher Teacher    @relation(fields: [ownerTeacherId], references: [id])
  questions    Question[]

  @@map("question_sets")
}

/// Bank soal
model Question {
  id             String       @id @default(uuid())
  subjectId      String       @map("subject_id")
  teacherId      String       @map("teacher_id")
  questionSetId  String?      @map("question_set_id")
  questionType   QuestionType @map("question_type")
  questionText   String       @map("question_text")
  mediaType      MediaType    @default(NONE) @map("media_type")
  mediaUrl       String?      @map("media_url")
  difficulty     Difficulty   @default(MEDIUM)
  scoreWeight    Float        @default(1) @map("score_weight")
  explanation    String?
  material       String?
  competency     String?
  grade          String?
  isRandomized   Boolean      @default(true) @map("is_randomized")
  randomizeOptions Boolean    @default(true) @map("randomize_options")
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  subject  Subject          @relation(fields: [subjectId], references: [id])
  teacher  Teacher          @relation(fields: [teacherId], references: [id])
  questionSet QuestionSet?  @relation(fields: [questionSetId], references: [id], onDelete: SetNull)
  options  QuestionOption[]
  examQuestions ExamQuestion[]
  answers  StudentAnswer[]

  @@map("questions")
}

/// Opsi jawaban (untuk soal PG, PGK, BS, Menjodohkan)
model QuestionOption {
  id          String  @id @default(uuid())
  questionId  String  @map("question_id")
  optionLabel String  @map("option_label") // A, B, C, D, E
  optionText  String  @map("option_text")
  mediaUrl    String? @map("media_url")
  isCorrect   Boolean @default(false) @map("is_correct")
  orderNumber Int     @default(0) @map("order_number")

  question Question        @relation(fields: [questionId], references: [id], onDelete: Cascade)
  answers  StudentAnswer[]

  @@map("question_options")
}

/// Ujian / Paket Ujian
model Exam {
  id                 String     @id @default(uuid())
  title              String
  subjectId          String     @map("subject_id")
  teacherId          String     @map("teacher_id")
  academicYearId     String?    @map("academic_year_id")
  durationMinutes    Int        @map("duration_minutes")
  startAt            DateTime   @map("start_at")
  endAt              DateTime   @map("end_at")
  randomizeQuestions Boolean    @default(false) @map("randomize_questions")
  randomizeOptions   Boolean    @default(false) @map("randomize_options")
  showResult         Boolean    @default(false) @map("show_result")
  showExplanation    Boolean    @default(false) @map("show_explanation")
  passingScore       Float?     @map("passing_score") // KKM
  status             ExamStatus @default(DRAFT)
  examType           ExamType   @default(UH) @map("exam_type")
  createdAt          DateTime   @default(now()) @map("created_at")
  updatedAt          DateTime   @updatedAt @map("updated_at")

  subject       Subject            @relation(fields: [subjectId], references: [id])
  teacher       Teacher            @relation(fields: [teacherId], references: [id])
  academicYear  AcademicYear?      @relation(fields: [academicYearId], references: [id])
  questions     ExamQuestion[]
  classes       ExamClass[]
  sessions      ExamSession[]
  tokens        ExamToken[]
  attempts      StudentExamAttempt[]

  @@map("exams")
}

/// Soal dalam ujian (relasi many-to-many)
model ExamQuestion {
  id          String @id @default(uuid())
  examId      String @map("exam_id")
  questionId  String @map("question_id")
  orderNumber Int    @default(0) @map("order_number")

  exam     Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id])

  @@unique([examId, questionId])
  @@map("exam_questions")
}

/// Kelas peserta ujian
model ExamClass {
  id      String @id @default(uuid())
  examId  String @map("exam_id")
  classId String @map("class_id")

  exam  Exam  @relation(fields: [examId], references: [id], onDelete: Cascade)
  class Class @relation(fields: [classId], references: [id])

  @@unique([examId, classId])
  @@map("exam_classes")
}

/// Sesi ujian
model ExamSession {
  id          String   @id @default(uuid())
  examId      String   @map("exam_id")
  sessionName String   @map("session_name")
  roomName    String?  @map("room_name")
  startAt     DateTime @map("start_at")
  endAt       DateTime @map("end_at")
  createdAt   DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_sessions")
}

/// Token ujian
model ExamToken {
  id        String   @id @default(uuid())
  examId    String   @map("exam_id")
  token     String   @unique
  expiredAt DateTime @map("expired_at")
  isActive  Boolean  @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  exam Exam @relation(fields: [examId], references: [id], onDelete: Cascade)

  @@map("exam_tokens")
}

/// Percobaan ujian siswa
model StudentExamAttempt {
  id          String        @id @default(uuid())
  examId      String        @map("exam_id")
  studentId   String        @map("student_id")
  startedAt   DateTime?     @map("started_at")
  submittedAt DateTime?     @map("submitted_at")
  status      AttemptStatus @default(NOT_STARTED)
  score       Float?
  loginStatus Boolean       @default(false) @map("login_status")
  ipAddress   String?       @map("ip_address")
  // Anti-cheat (mobile): kunci akses bila siswa berkali-kali keluar app
  isLocked       Boolean   @default(false) @map("is_locked")
  lockedAt       DateTime? @map("locked_at")
  lockReason     String?   @map("lock_reason")
  violationCount Int       @default(0) @map("violation_count")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  exam    Exam            @relation(fields: [examId], references: [id])
  student Student         @relation(fields: [studentId], references: [id])
  answers StudentAnswer[]

  @@unique([examId, studentId])
  @@map("student_exam_attempts")
}

/// Jawaban siswa
model StudentAnswer {
  id               String   @id @default(uuid())
  attemptId        String   @map("attempt_id")
  questionId       String   @map("question_id")
  selectedOptionId String?  @map("selected_option_id")
  answerText       String?  @map("answer_text")
  isDoubtful       Boolean  @default(false) @map("is_doubtful")
  isCorrect        Boolean? @map("is_correct")
  score            Float?
  savedAt          DateTime @default(now()) @map("saved_at")

  attempt        StudentExamAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question       Question           @relation(fields: [questionId], references: [id])
  selectedOption QuestionOption?    @relation(fields: [selectedOptionId], references: [id])

  @@unique([attemptId, questionId])
  @@map("student_answers")
}

/// Audit log (opsional)
model AuditLog {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  action    String
  entity    String?
  entityId  String?  @map("entity_id")
  details   String?
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("audit_logs")
}

/// Pengaturan sistem (key-value)
model SystemSetting {
  id        String   @id @default(uuid())
  key       String   @unique
  value     String
  category  String?
  updatedAt DateTime @updatedAt @map("updated_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("system_settings")
}

// ============================================
// LANDING PAGE / CMS MODELS
// ============================================

enum RegistrationStatus {
  PENDING
  VERIFIED
  ACCEPTED
  REJECTED
}

/// Profil & konten hero landing page (single record)
model LandingProfile {
  id           String   @id @default(uuid())
  schoolName   String   @default("SMK Hutama Pondok Gede") @map("school_name")
  shortName    String   @default("SMK Hutama") @map("short_name")
  tagline      String?
  logoUrl      String?  @map("logo_url")
  heroBadge    String?  @map("hero_badge")
  heroTitle    String?  @map("hero_title")
  heroSubtitle String?  @map("hero_subtitle")
  address      String?
  phone        String?
  whatsapp     String?
  email        String?
  officialUrl  String?  @map("official_url")
  instagram    String?
  facebook     String?
  youtube      String?
  ppdbOpen     Boolean  @default(true) @map("ppdb_open")
  vision       String?
  mission      String?
  history      String?
  principalName  String? @map("principal_name")
  principalPhoto String? @map("principal_photo")
  principalWord  String? @map("principal_word")
  updatedAt    DateTime @updatedAt @map("updated_at")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("landing_profiles")
}

/// Gambar carousel hero
model LandingHeroImage {
  id          String   @id @default(uuid())
  imageUrl    String   @map("image_url")
  caption     String?
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("landing_hero_images")
}

/// Statistik sekolah (akreditasi, jumlah siswa, dll)
model LandingStat {
  id          String   @id @default(uuid())
  label       String
  value       String
  orderNumber Int      @default(0) @map("order_number")

  @@map("landing_stats")
}

/// Program keahlian / jurusan landing
model LandingMajor {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")

  @@map("landing_majors")
}

/// Berita & kegiatan
model LandingNews {
  id          String   @id @default(uuid())
  slug        String   @unique
  title       String
  excerpt     String
  content     String?
  imageUrl    String?  @map("image_url")
  publishedAt DateTime @default(now()) @map("published_at")
  isPublished Boolean  @default(true) @map("is_published")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("landing_news")
}

/// Guru & tenaga pendidik (landing)
model LandingTeacher {
  id          String   @id @default(uuid())
  name        String
  position    String
  subject     String?
  photoUrl    String?  @map("photo_url")
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("landing_teachers")
}

/// Ekstrakurikuler (landing)
model LandingExtracurricular {
  id          String   @id @default(uuid())
  name        String
  category    String
  description String
  schedule    String?
  icon        String   @default("Sparkles")
  color       String   @default("from-blue-500 to-indigo-600")
  imageUrl    String?  @map("image_url")
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("landing_extracurriculars")
}

/// Pendaftaran online (PPDB)
model Registration {
  id            String             @id @default(uuid())
  registNumber  String             @unique @map("regist_number")
  fullName      String             @map("full_name")
  nisn          String?
  gender        Gender?
  birthPlace    String?            @map("birth_place")
  birthDate     DateTime?          @map("birth_date")
  address       String?
  phone         String?
  email         String?
  parentName    String?            @map("parent_name")
  parentPhone   String?            @map("parent_phone")
  originSchool  String?            @map("origin_school")
  selectedMajor String?            @map("selected_major")
  status        RegistrationStatus @default(PENDING)
  notes         String?
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")

  @@map("registrations")
}

/// Galeri foto sekolah (landing)
model LandingGallery {
  id          String   @id @default(uuid())
  imageUrl    String   @map("image_url")
  caption     String?
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("landing_gallery")
}

/// FAQ (landing)
model LandingFaq {
  id          String   @id @default(uuid())
  question    String
  answer      String
  orderNumber Int      @default(0) @map("order_number")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("landing_faq")
}

// ============================================
// BIMBINGAN KONSELING (SIBIKONS) MODELS
// ============================================

/// Profil Guru BK / Konselor
model Counselor {
  id        String   @id @default(uuid())
  userId    String   @unique @map("user_id")
  nip       String?  @unique
  phone     String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  cases        CounselingCase[]
  violations   ViolationRecord[]
  achievements AchievementRecord[]
  parentSummons ParentSummon[]
  homeVisits    HomeVisit[]

  @@map("counselors")
}

/// Master jenis pelanggaran + bobot poin
model ViolationType {
  id        String            @id @default(uuid())
  name      String
  category  ViolationCategory @default(RINGAN)
  points    Int               @default(0)
  isActive  Boolean           @default(true) @map("is_active")
  createdAt DateTime          @default(now()) @map("created_at")
  updatedAt DateTime          @updatedAt @map("updated_at")

  records ViolationRecord[]

  @@map("violation_types")
}

/// Sesi / kasus konseling
model CounselingCase {
  id             String           @id @default(uuid())
  studentId      String           @map("student_id")
  counselorId    String           @map("counselor_id")
  type           CounselingType   @default(PRIBADI)
  status         CounselingStatus @default(OPEN)
  title          String
  description    String?
  notes          String?          @map("session_notes")
  followUp       String?          @map("follow_up")
  isConfidential Boolean          @default(true) @map("is_confidential")
  sessionDate    DateTime         @default(now()) @map("session_date")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("counseling_cases")
}

/// Catatan pelanggaran siswa (poin negatif)
model ViolationRecord {
  id              String   @id @default(uuid())
  studentId       String   @map("student_id")
  counselorId     String   @map("counselor_id")
  violationTypeId String?  @map("violation_type_id")
  description     String
  points          Int      @default(0)
  sanction        String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now()) @map("created_at")

  student       Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor     Counselor      @relation(fields: [counselorId], references: [id])
  violationType ViolationType? @relation(fields: [violationTypeId], references: [id])

  @@map("violation_records")
}

/// Catatan prestasi siswa (poin positif)
model AchievementRecord {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  counselorId String   @map("counselor_id")
  title       String
  description String?
  points      Int      @default(0)
  level       String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("achievement_records")
}

/// Permohonan konseling yang diajukan siswa
model CounselingRequest {
  id            String        @id @default(uuid())
  studentId     String        @map("student_id")
  topic         String
  description   String?
  urgency       String        @default("SEDANG")
  preferredDate DateTime?      @map("preferred_date")
  status        RequestStatus @default(PENDING)
  response      String?
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("counseling_requests")
}

/// Surat pemanggilan orang tua
model ParentSummon {
  id          String       @id @default(uuid())
  studentId   String       @map("student_id")
  counselorId String       @map("counselor_id")
  level       String       // SP1 / SP2 / SP3 / PANGGILAN
  reason      String
  totalPoints Int          @default(0) @map("total_points")
  meetingDate DateTime?    @map("meeting_date")
  status      SummonStatus @default(PENDING)
  notes       String?
  createdAt   DateTime     @default(now()) @map("created_at")

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("parent_summons")
}

/// Kunjungan rumah (home visit)
model HomeVisit {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  counselorId String   @map("counselor_id")
  visitDate   DateTime @default(now()) @map("visit_date")
  purpose     String
  address     String?
  findings    String?
  result      String?
  createdAt   DateTime @default(now()) @map("created_at")

  student   Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  counselor Counselor @relation(fields: [counselorId], references: [id])

  @@map("home_visits")
}

/// Angket / asesmen kebutuhan siswa (AKPD)
model Survey {
  id          String   @id @default(uuid())
  title       String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  questions SurveyQuestion[]
  responses SurveyResponse[]

  @@map("surveys")
}

model SurveyQuestion {
  id          String  @id @default(uuid())
  surveyId    String  @map("survey_id")
  text        String
  category    String?
  orderNumber Int     @default(0) @map("order_number")

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@map("survey_questions")
}

model SurveyResponse {
  id          String   @id @default(uuid())
  surveyId    String   @map("survey_id")
  studentId   String   @map("student_id")
  submittedAt DateTime @default(now()) @map("submitted_at")

  survey  Survey         @relation(fields: [surveyId], references: [id], onDelete: Cascade)
  student Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  answers SurveyAnswer[]

  @@unique([surveyId, studentId])
  @@map("survey_responses")
}

model SurveyAnswer {
  id         String @id @default(uuid())
  responseId String @map("response_id")
  questionId String @map("question_id")
  value      Int    @default(0)

  response SurveyResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
  question SurveyQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([responseId, questionId])
  @@map("survey_answers")
}

// ============================================
// GURU PIKET MODELS
// ============================================

/// Kehadiran guru di kelas (dicatat guru piket)
model TeacherAttendance {
  id          String   @id @default(uuid())
  teacherId   String   @map("teacher_id")
  classId     String   @map("class_id")
  recordedBy  String   @map("recorded_by")
  status      String   // HADIR / TIDAK_HADIR / DIGANTIKAN / TUGAS_LUAR
  period      String?
  substitute  String?
  note        String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  teacher Teacher @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  class   Class   @relation(fields: [classId], references: [id], onDelete: Cascade)

  @@map("teacher_attendances")
}

/// Pendataan siswa terlambat
model StudentTardiness {
  id          String   @id @default(uuid())
  studentId   String   @map("student_id")
  recordedBy  String   @map("recorded_by")
  arrivalTime DateTime @map("arrival_time")
  reason      String?
  sanction    String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_tardiness")
}

/// Izin keluar/masuk siswa saat jam pelajaran
model StudentPermit {
  id          String    @id @default(uuid())
  studentId   String    @map("student_id")
  recordedBy  String    @map("recorded_by")
  type        String    // KELUAR / MASUK
  reason      String
  exitTime    DateTime? @map("exit_time")
  returnTime  DateTime? @map("return_time")
  status      String    @default("KELUAR") // KELUAR / SUDAH_KEMBALI / TIDAK_KEMBALI
  date        DateTime  @default(now())
  createdAt   DateTime  @default(now()) @map("created_at")

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("student_permits")
}
